# 팽팽클리닉 마켓 인텔리전스 환경 설정 (.env)
# 이 파일을 .env로 복사하고 실제 API 키를 입력하세요.

# [대시보드 링크 - 텔레그램 메시지에 포함]
# GitHub Pages 또는 다른 호스팅 URL 입력 (없으면 비워두세요)
# 예: DASHBOARD_URL=https://yourname.github.io/pp-clinic/dashboard.html
DASHBOARD_URL=

# [Naver API] https://developers.naver.com/
NAVER_CLIENT_ID=your_naver_id_here
NAVER_CLIENT_SECRET=your_naver_secret_here

# [Notion API] https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key_here
NOTION_MASTER_DB_ID=your_master_db_id_here
NOTION_LOG_DB_ID=your_log_db_id_here

# [Google Gemini API] https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# [YouTube Data API v3] https://console.cloud.google.com/apis/library/youtube.googleapis.com
# 무료 쿼터: 10,000 units/day | Shorts 검색, 조회수/좋아요 수집
YOUTUBE_API_KEY=your_youtube_api_key_here

# [Apify] https://console.apify.com/account/integrations
# Instagram Hashtag Scraper + TikTok Hashtag Scraper Actor 사용
# 무료 플랜: $5 크레딧/월 (소규모 수집 가능)
APIFY_API_TOKEN=your_apify_token_here

# [Global Targets]
TARGET_REGIONS=KR,JP,CN
HEURISTIC_KEYWORD_COUNT=100

# [SNS Layer 1 수집 설정]
# 수집할 키워드 (쉼표 구분, 미설정시 기본 키워드 사용)
SNS_KEYWORDS=실리프팅,피부관리,강남피부과,안티에이징,울쎄라
# 키워드당 최대 수집 게시물 수
SNS_MAX_PER_KEYWORD=5

# ─────────────────────────────────────────────────────────────
# [Dashboard KPI - 수동 입력]
# data_generator.py 실행 시 아래 값이 dashboard_data.json에 반영됩니다.
# CRM 연동 전까지 매일 수동으로 업데이트하세요.
# ─────────────────────────────────────────────────────────────
# 오늘 카카오/전화 문의 건수
MANUAL_KPI_INQUIRIES=47
# 오늘 실제 예약 성사 건수
MANUAL_KPI_BOOKINGS=23
# 오늘 '실리프팅' 관련 주요 검색량 (Naver DataLab에서 확인)
MANUAL_KPI_SEARCH_VOL=3840
# 오늘 경쟁사 리뷰 크롤러가 포착한 부작용/리스크 건수
MANUAL_KPI_RISKS=3

